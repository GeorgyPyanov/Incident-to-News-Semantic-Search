# Copy this file to .env and fill in values for your local environment.

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:55432/incident_news_search
EMBEDDING_DIM=384
EMBEDDING_MODEL=intfloat/e5-small-v2
EMBEDDING_BACKEND=auto
EMBEDDING_QUANTIZATION=none
EMBEDDING_QUERY_PREFIX=query: 
EMBEDDING_DOCUMENT_PREFIX=passage: 
RETRIEVAL_FUSION_MODE=rrf
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_SECONDS=60
DEEPSEEK_ANSWER_MAX_TOKENS=2500
DEEPSEEK_RERANK_ENABLED=false
DEEPSEEK_RERANK_TOP_N=12
RAG_GENERATOR_PROVIDER=deepseek
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TIMEOUT_SECONDS=60
RAG_RETRIEVAL_MODE=hybrid
RAG_MIN_TOP_SCORE=0.35
RAG_MIN_SUPPORTING_DOCS=1
RAG_MIN_EVIDENCE_OVERLAP=0.12

# Application
APP_ENV=development
LOG_LEVEL=INFO
